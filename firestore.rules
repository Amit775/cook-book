rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles. A signed-in user may read profiles (for author display)
    // but may only create/update their own. Profiles are not deletable.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      // Private saved-recipes list, owned by the user.
      match /savedRecipes/{recipeId} {
        allow read, write: if isOwner(userId);
      }

      // Private recipe collections, owned by the user.
      match /collections/{collectionId} {
        allow read, write: if isOwner(userId);
      }

      // Private shopping lists, owned by the user.
      match /shoppingLists/{listId} {
        allow read, write: if isOwner(userId);
      }

      // Private weekly meal plans, owned by the user.
      match /mealPlans/{weekStartDate} {
        allow read, write: if isOwner(userId);
      }
    }

    // Share links: an unguessable token -> recipe id, for "anyone with the link".
    // Readable only by exact id (get), never enumerable (list). The owner of the
    // target recipe manages them.
    match /shareLinks/{shareId} {
      function ownsTargetRecipe(recipeId) {
        return isSignedIn()
          && get(/databases/$(database)/documents/recipes/$(recipeId)).data.authorId == request.auth.uid;
      }
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if ownsTargetRecipe(request.resource.data.recipeId);
      allow delete: if ownsTargetRecipe(resource.data.recipeId);
      allow update: if false;
    }

    // Shared ingredient catalog. Any signed-in user may read it (for the editor's
    // autocomplete) and append new entries; entries are immutable and shared, so
    // no updates or deletes. `nameLower` powers prefix search and de-duplication.
    match /ingredients/{ingredientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'nameLower', 'createdBy', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() > 0
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Recipes. Read access depends on visibility; writes are author-only, except
    // a signed-in visitor may add ONLY themselves to `sharedWith` (joining via a
    // share link), or bump only the three rating aggregate fields (ratingCount,
    // ratingSum, ratingAverage) as part of the client-side rating transaction.
    // NOTE: Firestore evaluates rules per document. List/collection queries must
    // include filters (e.g. visibility == 'public', or sharedWith contains uid)
    // that match these conditions, otherwise the whole query is rejected.
    match /recipes/{recipeId} {

      function canReadRecipe() {
        let recipe = resource.data;
        return recipe.visibility == 'public'
          || recipe.visibility == 'unlisted'
          || (isSignedIn() && (
                request.auth.uid == recipe.authorId
                || request.auth.uid in recipe.sharedWith
             ));
      }

      // A non-owner may only add their own uid to `sharedWith` (and bump updatedAt),
      // changing nothing else.
      function isSelfJoin() {
        let added = request.resource.data.sharedWith;
        let existing = resource.data.sharedWith;
        return isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWith', 'updatedAt'])
          && !(request.auth.uid in existing)
          && added.hasAll(existing)
          && added.hasOnly(existing.concat([request.auth.uid]));
      }

      // A signed-in rater (who can already read the recipe) may update ONLY the
      // three aggregate fields that the rating transaction touches. The rating write
      // must NOT change `updatedAt` or any other recipe field, keeping this branch
      // unambiguous and preventing aggregate-only writes from reordering recipe lists.
      // Accepted limitation: rules cannot cross-check the delta against the rater's
      // individual rating doc in the same transaction (no cross-doc read in condition
      // expressions), so a determined client could set arbitrary non-negative numbers.
      // Tamper-proof aggregation via a callable is deferred to a future issue.
      function isRatingAggregateWrite() {
        return isSignedIn() && canReadRecipe()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['ratingCount', 'ratingSum', 'ratingAverage']);
      }

      allow read: if canReadRecipe();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) || isSelfJoin() || isRatingAggregateWrite();
      allow delete: if isOwner(resource.data.authorId);

      // Comments are public-readable; authored and editable only by their author.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }

      // Ratings: one doc per rater (doc id == rater uid → one-per-user structurally).
      //
      // IMPORTANT: inside this nested match block, `resource` refers to the rating
      // doc itself (or is null on create), NOT to the parent recipe doc. We therefore
      // gate access on the PARENT recipe using a cross-doc `get()` so we can evaluate
      // the recipe's actual visibility/authorId/sharedWith fields.
      //
      // `canViewParentRecipe()` mirrors the logic of `canReadRecipe()` above but reads
      // from the fetched recipe snapshot instead of `resource.data`.
      match /ratings/{userId} {
        function parentRecipe() {
          return get(/databases/$(database)/documents/recipes/$(recipeId)).data;
        }

        function canViewParentRecipe() {
          let recipe = parentRecipe();
          return recipe.visibility == 'public'
            || recipe.visibility == 'unlisted'
            || (isSignedIn() && (
                  request.auth.uid == recipe.authorId
                  || request.auth.uid in recipe.sharedWith
               ));
        }

        allow read: if canViewParentRecipe();
        allow create, update: if isOwner(userId) && canViewParentRecipe()
          && request.resource.data.authorId == userId
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1 && request.resource.data.stars <= 5
          && request.resource.data.reviewText is string
          && request.resource.data.reviewText.size() <= 1000;
        allow delete: if isOwner(userId);
      }
    }
  }
}
