rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Recipe cover photos live under recipe-photos/{userId}/{fileName}.
    // Anyone can read; only the owning user can upload, and only images < 5 MB.
    match /recipe-photos/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
